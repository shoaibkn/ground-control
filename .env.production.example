# Global Ground Control Production Environment Variables Example
# Do not commit actual secrets to version control. Copy this to your production environment management panel (e.g. Vercel, Netlify, Convex).

# ==========================================
# 1. Convex Backend Environment Variables
# (Configure these on your Convex Dashboard under Settings > Environment Variables)
# ==========================================

# The production URL of the Next.js frontend
SITE_URL=https://your-app-domain.com

# Better Auth Secret (Generate a strong 32-byte key: `openssl rand -hex 32`)
BETTER_AUTH_SECRET=your_32_byte_better_auth_secret_here

# OAuth credentials for production
GOOGLE_CLIENT_ID=your_production_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_production_google_client_secret

# Resend & Email configuration
EMAIL_FROM=Ground Control <onboarding@yourdomain.com>
# Note: Add RESEND_API_KEY if using Resend for production emails (or configure resend component)


# ==========================================
# 2. Next.js Web Frontend Environment Variables
# (Configure these on your Vercel/hosting provider environment variables panel)
# ==========================================

# Production Convex deployment details (get these from your Convex dashboard)
NEXT_PUBLIC_CONVEX_URL=https://your-production-subdomain.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-production-subdomain.convex.site

# Production Canonical Site URL (Matches SITE_URL above)
NEXT_PUBLIC_SITE_URL=https://your-app-domain.com

# Better Auth production settings
BETTER_AUTH_SECRET=your_32_byte_better_auth_secret_here
BETTER_AUTH_URL=https://your-app-domain.com

# Google OAuth Credentials for client components (if needed, matching backend)
GOOGLE_CLIENT_ID=your_production_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_production_google_client_secret
