# Convex Backend Production Environment Variables Template
# Copy these to your Convex dashboard settings under "Environment Variables"

# Production Canonical Site URL (Matches Next.js app url)
SITE_URL=https://your-app-domain.com

# Better Auth Secret (Should match web frontend configuration, generate via `openssl rand -hex 32`)
BETTER_AUTH_SECRET=your_32_byte_better_auth_secret_here

# Google OAuth credentials (if oauth is used in production)
GOOGLE_CLIENT_ID=your_production_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_production_google_client_secret

# Production Resend sender email address
EMAIL_FROM=Ground Control <onboarding@yourdomain.com>
# Note: Add RESEND_API_KEY if configured in Resend package or CLI
