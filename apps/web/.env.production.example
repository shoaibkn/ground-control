# Next.js Production Environment Variables Template
# Copy these to your production hosting provider (e.g. Vercel, Netlify)

# Production Convex deployment details (from Convex Dashboard)
NEXT_PUBLIC_CONVEX_URL=https://your-production-subdomain.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-production-subdomain.convex.site

# Production Canonical Site URL (Matches your domain)
NEXT_PUBLIC_SITE_URL=https://your-app-domain.com

# Better Auth Secret (Should match the backend configuration, generate via `openssl rand -hex 32`)
BETTER_AUTH_SECRET=your_32_byte_better_auth_secret_here

# Better Auth Canonical URL (Typically the site URL)
BETTER_AUTH_URL=https://your-app-domain.com

# Google OAuth credentials (if oauth is used in production)
GOOGLE_CLIENT_ID=your_production_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_production_google_client_secret
